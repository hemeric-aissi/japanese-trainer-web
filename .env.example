# ── Copie ce fichier en .env et remplis les valeurs ──────────────
# Ne jamais commiter .env — seul .env.example va dans Git

# Base de données
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=japanese_trainer
DB_USER=jt_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_ROOT_PASSWORD=CHANGE_ME_root_password_here

# Application
APP_ENV=development        # development | production
APP_SECRET=CHANGE_ME_32chars_random_string_here
SESSION_LIFETIME=3600      # secondes (1h)

# Sécurité
BCRYPT_COST=12             # coût de hachage bcrypt (12 = bon équilibre)
